{
    "version": "0.10.0",
    "description": "AI-native design editor. Open-source Figma alternative.",
    "homepage": "https://openpencil.dev",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-pencil/open-pencil/releases/download/v0.10.0/OpenPencil_0.10.0_x64-setup.exe#/installer.exe",
            "hash": "6169a1115794d83091c1b5a57ec88462ddc7a1cb4450009e82b1c0d36f669bcd"
        },
        "arm64": {
            "url": "https://github.com/open-pencil/open-pencil/releases/download/v0.10.0/OpenPencil_0.10.0_arm64-setup.exe#/installer.exe",
            "hash": "a7c7a4f20f6ddac773801a5ae0dd9851086137c190835771d2945d714268dee5"
        }
    },
    "installer": {
        "script": [
            "$tmpDir = Join-Path $dir '_tmp'",
            "Expand-7zipArchive \"$dir\\installer.exe\" $tmpDir -Removal",
            "Move-Item (Join-Path $tmpDir 'OpenPencil.exe') $dir -Force",
            "Remove-Item $tmpDir -Recurse -Force -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "OpenPencil.exe",
            "OpenPencil"
        ]
    ],
    "portableProfile": {
        "mappings": [
            {
                "label": "roaming",
                "source": "AppData/net.dannote.open-pencil",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            }
        ],
        "options": {
            "log": true
        }
    },
    "checkver": {
        "github": "https://github.com/open-pencil/open-pencil"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-pencil/open-pencil/releases/download/v$version/OpenPencil_$version_x64-setup.exe#/installer.exe"
            },
            "arm64": {
                "url": "https://github.com/open-pencil/open-pencil/releases/download/v$version/OpenPencil_$version_arm64-setup.exe#/installer.exe"
            }
        }
    }
}

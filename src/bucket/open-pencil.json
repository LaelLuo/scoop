{
    "version": "0.4.4",
    "description": "The world's first open-source AI-native vector design tool and the first to feature concurrent Agent Teams.",
    "homepage": "https://op.zseven.tech",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/ZSeven-W/openpencil/releases/download/v0.4.4/OpenPencil-0.4.4-x64-win-setup.exe#/dl.7z",
            "hash": "19a1d4fa30ed0cae2d9daf8b604cf5f4ba203f7854319cbd6b26fac68443e4d4",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        }
    },
    "shortcuts": [
        [
            "OpenPencil.exe",
            "OpenPencil"
        ]
    ],
    "portableProfile": {
        "mappings": [
            {
                "label": "roaming",
                "source": "AppData/OpenPencil",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "home-port",
                "source": "UserProfile/.openpencil",
                "target": "$persist_dir/home/openpencil",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "updater",
                "source": "LocalAppData/openpencil-updater",
                "target": "$persist_dir/local/openpencil-updater",
                "strategy": "symlink",
                "ensureTarget": true,
                "targetType": "file"
            }
        ],
        "options": {
            "log": true
        }
    },
    "post_install": [
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "checkver": {
        "script": [
            "$releases = Invoke-RestMethod -Uri 'https://api.github.com/repos/ZSeven-W/openpencil/releases?per_page=20'",
            "$latest = $releases | Where-Object { -not $_.draft -and $_.tag_name -match '^v?\\d+\\.\\d+\\.\\d+$' } | Sort-Object -Property @{ Expression = { [version]($_.tag_name.TrimStart('v')) } } -Descending | Select-Object -First 1",
            "if (-not $latest) {",
            "  throw 'Failed to locate the latest OpenPencil release.'",
            "}",
            "Write-Output $latest.tag_name"
        ],
        "regex": "^v(?<version>.+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ZSeven-W/openpencil/releases/download/v$version/OpenPencil-$version-x64-win-setup.exe#/dl.7z"
            }
        }
    }
}

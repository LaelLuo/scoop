{
    "version": "0.2.0",
    "description": "An app for managing GitHub starred repositories.",
    "homepage": "https://github.com/AmintaCCCP/GithubStarsManager",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v0.2.0/GitHub.Stars.Manager.Setup.0.2.0.exe#/dl.7z",
            "hash": "74aeb741247b4c8173d772af4d1cb3b2402e44185abebda8e04ba77930c55c95",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        }
    },
    "shortcuts": [
        [
            "GitHub Stars Manager.exe",
            "GitHub Stars Manager"
        ]
    ],
    "post_install": [
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "portableProfile": {
        "mappings": [
            {
                "label": "roaming",
                "source": "AppData/github-stars-manager",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            }
        ],
        "options": {
            "log": true
        }
    },
    "checkver": {
        "github": "https://github.com/AmintaCCCP/GithubStarsManager"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v$version/GitHub.Stars.Manager.Setup.$version.exe#/dl.7z"
            }
        }
    }
}
